{
  "name": "srt-lyric-player",
  "version": "0.1.1",
  "description": "A React component library for music players with real-time SRT lyric sync and audio visualization",
  "keywords": ["react", "music-player", "lyrics", "srt", "audio-visualizer"],
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./dist/index.css": "./dist/index.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "framer-motion": ">=11",
    "howler": ">=2.2"
  },
  "dependencies": {
    "srt-parser-2": "^1.2.3"
  },
  "devDependencies": {
    "@types/howler": "^2.2.12",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "tsup": "^8",
    "typescript": "^5"
  }
}
